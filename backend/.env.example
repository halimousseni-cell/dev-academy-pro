# Copier ce fichier en .env et renseigner des valeurs réelles.
# Ne JAMAIS committer le fichier .env.

# Base de données (PostgreSQL)
# - En local (postgres lancé via `docker compose up -d db` avec le port
#   5432 publié) : postgresql://devacademy:devacademy@localhost:5432/devacademy
# - Depuis le conteneur backend (Docker Compose) : remplacer "localhost" par
#   le nom du service "db" -> postgresql://devacademy:devacademy@db:5432/devacademy
DATABASE_URL="postgresql://devacademy:devacademy@localhost:5432/devacademy"

# Port d'écoute du serveur
PORT=4000

# Origine autorisée pour CORS (frontend Vite)
FRONTEND_ORIGIN="http://localhost:5173"

# Secrets JWT — générer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="changez-moi-secret-access-tres-long-et-aleatoire"
JWT_REFRESH_PEPPER="changez-moi-pepper-pour-hash-refresh-token"

# Durées de vie des tokens
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7

# Environnement
NODE_ENV="development"

# Cookie de refresh token marqué "Secure" (nécessite HTTPS). Laisser à
# "false" en local/HTTP (docker compose sans Nginx+TLS). Mettre "true"
# uniquement derrière un reverse proxy HTTPS. Si absent, la valeur par
# défaut suit NODE_ENV (true en production).
COOKIE_SECURE="false"
