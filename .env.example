# Copier ce fichier en .env (racine du projet) pour Docker Compose.
# Ne JAMAIS committer le fichier .env.

# --- PostgreSQL ---
POSTGRES_USER=devacademy
POSTGRES_PASSWORD=changez-moi-mot-de-passe-postgres
POSTGRES_DB=devacademy

# --- Secrets JWT (backend) ---
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=changez-moi-secret-access-tres-long-et-aleatoire
JWT_REFRESH_PEPPER=changez-moi-pepper-pour-hash-refresh-token

# --- Origine du frontend (CORS + cookies) ---
# En local (docker-compose.yml seul) : http://localhost:8080
# En production (avec docker-compose.prod.yml) : https://<DOMAIN>
FRONTEND_ORIGIN=http://localhost:8080

# Cookie de refresh token "Secure" — false en local/HTTP (pas de TLS via
# Nginx). Mettre "true" une fois le reverse proxy HTTPS en place
# (docker-compose.prod.yml).
COOKIE_SECURE=false

# --- Reverse proxy HTTPS (docker-compose.prod.yml uniquement) ---
# Nom de domaine pointant vers ce serveur (DNS A/AAAA) et adresse e-mail
# utilisée pour les notifications Let's Encrypt (expiration de certificat).
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# --- Sauvegardes PostgreSQL chiffrées (service "backup") ---
# Clé de chiffrement AES-256 des sauvegardes (pg_dump | gzip | openssl enc).
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# À conserver précieusement et séparément des sauvegardes : sans elle, les
# fichiers .sql.gz.enc sont irrécupérables.
BACKUP_ENCRYPTION_KEY=changez-moi-cle-de-chiffrement-des-sauvegardes
# Fréquence (en heures) et durée de conservation (en jours) des sauvegardes.
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
